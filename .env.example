# Copy to .env and fill in. Grab keys from the sponsor starter packs on live.hackberkeley.org at kickoff.

# Anthropic — powers structure() + heal() (the re-grounding reasoning). REQUIRED.
ANTHROPIC_API_KEY=sk-ant-...

# Redis — stores workflows + heal history (the "agent memory" prize). REQUIRED.
# Local: redis://localhost:6379   |   Redis Cloud: redis://default:<pw>@<host>:<port>
REDIS_URL=redis://localhost:6379

# Sentry — captures step failures (bonus points for the Sentry prize). OPTIONAL.
SENTRY_DSN=

# Server port for the runtime + web UI.
PORT=3000

# Browserbase — OPTIONAL stretch. Leave blank to use local Playwright (the demo default).
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
